# =========================================================
# .env.example
# Plantilla pública de variables de entorno.
# Copiar este archivo a `.env` y completar valores reales.
# El archivo `.env` NUNCA debe subirse al repositorio.
# =========================================================

# ---------- Django ----------
SECRET_KEY=cambiar-esta-clave-en-produccion
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ---------- PostgreSQL ----------
POSTGRES_DB=simulador_db
POSTGRES_USER=simulador_user
POSTGRES_PASSWORD=simulador_pass
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Puerto expuesto al host (Windows) — solo para DBeaver/pgAdmin. Si tienes otro
# Postgres corriendo en 5432, cambia este. El contenedor sigue usando 5432 internamente.
POSTGRES_HOST_PORT=5435

# ---------- CORS ----------
# URLs del frontend autorizadas a consumir la API (separadas por coma)
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# ---------- JWT ----------
# Tiempo de vida del access token en minutos
JWT_ACCESS_LIFETIME_MIN=60
# Tiempo de vida del refresh token en días
JWT_REFRESH_LIFETIME_DAYS=7

# ---------- IA generativa (se usarán en fases posteriores) ----------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------- Correo (notificaciones a estudiantes, fases posteriores) ----------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@simulador.local
