        "descripcion": "En UCI confirma empujón durante agresión",
        "personajeId": "lucia"
      },
      "efectosAlMostrar": [
        {
          "tipo": "completar_conversacion",
          "parametros": { "conversacionId": "revisita-lucia-informe" }
        }
      ]
    }
  ]
}
