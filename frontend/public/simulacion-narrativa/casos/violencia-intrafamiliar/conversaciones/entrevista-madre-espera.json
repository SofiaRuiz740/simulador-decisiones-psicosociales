      "id": "apertura",
      "emisor": "personaje",
      "personajeId": "lucia",
      "texto": "Doctora… perdí a mi hija hace unas horas. Yo también estoy muy mal… no sé si me van a operar. Por favor, dígame qué está pasando.",
      "siguienteNodoId": "decision-noticia"
    },
    {
      "id": "decision-noticia",
      "emisor": "jugador",
      "texto": "Cómo responder ante la pérdida reciente",
      "opciones": [
        {
          "id": "validar-duelo",
