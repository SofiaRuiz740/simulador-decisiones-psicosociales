{
  "id": "entrevista-enfermera-pasillo",
  "titulo": "Enfermera de urgencias",
  "escenarioId": "consulta-inicial",
  "personajeId": "enfermera",
  "nodoInicialId": "apertura",
  "cuentaComoUtil": true,
  "nodos": [
    {
      "id": "apertura",
      "emisor": "personaje",
      "personajeId": "enfermera",
      "texto": "Buenas. Esta noche ha sido pesada en urgencias. ¿Viene por la paciente del trauma o necesita que la oriente con algo?",
      "siguienteNodoId": "decision-prep-exploracion-inicial"
    },
    {
      "id": "decision-prep-exploracion-inicial",
      "emisor": "jugador",
      "texto": "La enfermera tiene un momento. Piensa cómo abrir la conversación.",
      "opciones": [
        {
          "id": "prep-slot-enf-exploracion-1",
          "texto": "«¿Cómo está el servicio esta noche? ¿Hay restricciones para visitas?»",
          "estrategiaClinica": "exploracion",
          "siguienteNodoId": "enf-explor-servicio",
          "efectos": [
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "prep_rubrica_enf_exploracion",
                "valor": true
              }
            }
          ]
        },
        {
          "id": "prep-slot-enf-exploracion-2",
          "texto": "«Intervengo en el caso de la paciente ingresada. ¿Con quién coordino para verla?»",
          "estrategiaClinica": "exploracion",
          "siguienteNodoId": "enf-explor-coordinacion",
          "efectos": [
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "prep_rubrica_enf_exploracion",
                "valor": true
              }
            }
          ]
        },
        {
          "id": "prep-slot-enf-exploracion-3",
          "texto": "«¿Cómo fue el ingreso, en líneas generales?»",
          "estrategiaClinica": "exploracion",
          "siguienteNodoId": "enf-explor-dinamica",
          "efectos": [
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "prep_rubrica_enf_exploracion",
                "valor": true
              }
            }
          ]
        }
      ]
    },
    {
      "id": "enf-explor-servicio",
      "emisor": "personaje",
      "personajeId": "enfermera",
      "texto": "Hay mucha gente esperando y poco personal. En UCI solo entra quien esté autorizado; si va para allá, avise antes en guardia.",
      "siguienteNodoId": "decision-prep-profundizacion"
    },
    {
      "id": "enf-explor-coordinacion",
      "emisor": "personaje",
      "personajeId": "enfermera",
      "texto": "Los datos clínicos finos los tiene el médico tratante. Yo le puedo contar lo que vimos en enfermería cuando ingresó.",
      "siguienteNodoId": "decision-prep-profundizacion"
    },
    {
      "id": "enf-explor-dinamica",
      "emisor": "personaje",
      "personajeId": "enfermera",
      "texto": "Llegó una paciente muy grave y la familia venía alterada. El pasillo estuvo tenso un rato; estamos tratando de ordenar las visitas.",
      "siguienteNodoId": "decision-prep-profundizacion"
    },
    {
      "id": "decision-prep-profundizacion",
      "emisor": "jugador",
      "texto": "Lo que escuchaste deja preguntas abiertas. Piensa qué conviene profundizar.",
      "opciones": [
        {
          "id": "prep-slot-enf-profundizacion-1",
          "texto": "«¿Cómo la tienen ahora y quién puede entrar al box?»",
          "estrategiaClinica": "exploracion",
          "siguienteNodoId": "enf-profun-estado",
          "efectos": [
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "prep_rubrica_enf_profundizacion",
                "valor": true
              }
            }
          ]
        },
        {
          "id": "prep-slot-enf-profundizacion-2",
          "texto": "«¿Qué pasó con la familia en el pasillo cuando ingresó?»",
          "estrategiaClinica": "exploracion",
          "siguienteNodoId": "enf-profun-familia",
          "efectos": [
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "prep_rubrica_enf_profundizacion",
                "valor": true
              }
            }
          ]
        },
        {
          "id": "prep-slot-enf-profundizacion-3",
          "texto": "«¿Quedó anotado algo relevante en el ingreso?»",
          "estrategiaClinica": "exploracion",
          "siguienteNodoId": "enf-profun-observaciones-teaser",
          "efectos": [
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "prep_rubrica_enf_profundizacion",
                "valor": true
              }
            }
          ]
        }
      ]
    },
    {
      "id": "enf-profun-estado",
      "emisor": "personaje",
      "personajeId": "enfermera",
      "texto": "Está estable hemodinámicamente, pero sedada. Glasgow bajo al ingreso. Solo entra personal identificado al box; si va a UCI, lleve credencial.",
      "siguienteNodoId": "decision-prep-info-critica"
    },
    {
      "id": "enf-profun-familia",
      "emisor": "personaje",
      "personajeId": "enfermera",
      "texto": "Discutían en el pasillo sobre ‘de quién fue la culpa’. Activamos manejo de crisis; ustedes de salud mental suelen iniciar con primeros auxilios psicológicos cuando la familia llega así. Un hombre fue retirado; Carmen, la mamá de Lucía, y su hijo Diego siguieron muy alterados.",
      "siguienteNodoId": "decision-prep-info-critica"
    },
    {
      "id": "enf-profun-observaciones-teaser",
      "emisor": "personaje",
      "personajeId": "enfermera",
      "texto": "Hay anotaciones sobre lesiones visibles y sobre lo que dijo la familia. Si lo necesita para su evaluación, le amplío.",
      "siguienteNodoId": "decision-prep-info-critica"
    },
    {
      "id": "decision-prep-info-critica",
      "emisor": "jugador",
      "texto": "Hay datos del ingreso que merecen atención. Piensa cuál conviene precisar primero.",
      "opciones": [
        {
          "id": "prep-slot-enf-critica-1",
          "texto": "«¿Qué anotaron sobre las lesiones que vieron al ingreso?»",
          "estrategiaClinica": "exploracion",
          "siguienteNodoId": "enfermera-lesiones",
          "efectos": [
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "prep_rubrica_enf_info_critica",
                "valor": true
              }
            }
          ]
        },
        {
          "id": "prep-slot-enf-critica-2",
          "texto": "«¿Recuerda algo más de cómo se comportó la familia en el pasillo?»",
          "estrategiaClinica": "exploracion",
          "siguienteNodoId": "enfermera-familia-detalle",
          "efectos": [
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "prep_rubrica_enf_info_critica",
                "valor": true
              }
            }
          ]
        },
        {
          "id": "prep-slot-enf-critica-3",
          "texto": "«¿Pasó algo más esa noche en urgencias que deba tener en cuenta?»",
          "estrategiaClinica": "exploracion",
          "siguienteNodoId": "enfermera-dinamica-detalle",
          "efectos": [
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "prep_rubrica_enf_info_critica",
                "valor": true
              }
            }
          ]
        }
      ]
    },
    {
      "id": "enfermera-lesiones",
      "emisor": "personaje",
      "personajeId": "enfermera",
      "texto": "Anotamos moretones visibles en brazos y marca en el rostro al ingreso. La familia insistía en ‘caída en el baño’. Nosotras registramos lo observable; el mecanismo lo precisa el médico en el informe.",
      "testimonio": {
        "id": "testimonio-enfermera-lesiones",
        "tema": "mecanismo_lesion",
        "valor": "compatible_con_defensa",
        "descripcion": "Enfermería registra lesiones incompatibles con caída en baño",
        "personajeId": "enfermera"
      },
      "siguienteNodoId": "decision-cierre"
    },
    {
      "id": "enfermera-familia-detalle",
      "emisor": "personaje",
      "personajeId": "enfermera",
      "texto": "El joven lloraba en silencio; Carmen, la madre de Lucía, repetía que ‘Lucía es torpe’. Eso me inquietó porque sonaba a culpar a la víctima.",
      "testimonio": {
        "id": "testimonio-enfermera-altercado",
        "tema": "clima_familiar",
        "valor": "altercado_pasillo",
        "descripcion": "Altercado en pasillo; agresor retirado del área",
        "personajeId": "enfermera"
      },
      "siguienteNodoId": "decision-cierre"
    },
    {
      "id": "enfermera-dinamica-detalle",
      "emisor": "personaje",
      "personajeId": "enfermera",
      "texto": "El ingreso coincidió con otra víctima menor que ya llegó sin signos vitales. Eso activó un protocolo aparte; la paciente adulta siguió por la ruta de trauma.",
      "siguienteNodoId": "decision-cierre"
    },
    {
      "id": "decision-cierre",
      "emisor": "jugador",
      "texto": "Es momento de definir tu siguiente paso.",
      "opciones": [
        {
          "id": "prep-slot-enf-cierre-1",
          "texto": "«¿Me puede dejar el reporte de enfermería del ingreso para revisarlo?»",
          "estrategiaClinica": "exploracion",
          "siguienteNodoId": "cierre-enfermera-dialogo",
          "efectos": [
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "prep_rubrica_enf_cierre",
                "valor": true
              }
            },
            {
              "tipo": "descubrir_evidencia",
              "parametros": {
                "evidenciaId": "informe-urgencias"
              }
            }
          ]
        },
        {
          "id": "prep-slot-enf-cierre-2",
          "texto": "«Prefiero ir primero con la familia antes de revisar papeles.»",
          "estrategiaClinica": "contencion_emocional",
          "siguienteNodoId": "cierre-enfermera-dialogo",
          "efectos": [
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "prep_rubrica_enf_cierre",
                "valor": true
              }
            }
          ]
        },
        {
          "id": "prep-slot-enf-cierre-3",
          "texto": "«Para entender lesiones y evolución, ¿con quién del equipo médico hablo?»",
          "estrategiaClinica": "exploracion",
          "siguienteNodoId": "cierre-enfermera-dialogo",
          "efectos": [
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "prep_rubrica_enf_cierre",
                "valor": true
              }
            }
          ]
        }
      ]
    },
    {
      "id": "cierre-enfermera-dialogo",
      "emisor": "personaje",
      "personajeId": "enfermera",
      "texto": "Dejo el reporte en estación médica cuando esté listo. Si necesita detalle sobre lesiones, evolución o el TCE, el médico tratante lo tiene más claro.",
      "siguienteNodoId": "format-ref-d1-enfermera"
    },
    {
      "id": "format-ref-d1-enfermera",
      "emisor": "jugador",
      "texto": "La enfermera te orientó sobre el ingreso. Antes de seguir, piensa cuál sería el paso más prudente.",
      "opciones": [
        {
          "id": "format-d1-a",
          "texto": "Intentar entrevistar inmediatamente a Lucía.",
          "estrategiaClinica": "exploracion",
          "siguienteNodoId": "feedback-format-d1-a",
          "efectos": [
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "format_ref_d1",
                "valor": "A"
              }
            }
          ]
        },
        {
          "id": "format-d1-b",
          "texto": "Esperar información médica sobre su estabilidad.",
          "estrategiaClinica": "contencion_emocional",
          "siguienteNodoId": "feedback-format-d1-b",
          "efectos": [
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "format_ref_d1",
                "valor": "B"
              }
            }
          ]
        },
        {
          "id": "format-d1-c",
          "texto": "Solicitar información policial antes de cualquier intervención.",
          "estrategiaClinica": "exploracion",
          "siguienteNodoId": "feedback-format-d1-c",
          "efectos": [
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "format_ref_d1",
                "valor": "C"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "feedback-format-d1-a",
      "emisor": "narrador",
      "texto": "El personal médico informa que la paciente aún no está en condiciones para una entrevista clínica.",
      "siguienteNodoId": "cierre-enfermera"
    },
    {
      "id": "feedback-format-d1-b",
      "emisor": "narrador",
      "texto": "Esperar la valoración médica permite planificar la intervención psicológica con mayor seguridad.",
      "siguienteNodoId": "cierre-enfermera"
    },
    {
      "id": "feedback-format-d1-c",
      "emisor": "narrador",
      "texto": "La información policial puede aportar contexto, pero la condición clínica de la paciente sigue siendo prioritaria.",
      "siguienteNodoId": "cierre-enfermera"
    },
    {
      "id": "cierre-enfermera",
      "emisor": "narrador",
      "texto": "Cierras la entrevista con enfermería. El reporte queda disponible en estación médica.",
      "efectosAlMostrar": [
        {
          "tipo": "completar_conversacion",
          "parametros": {
            "conversacionId": "entrevista-enfermera-pasillo"
          }
        }
      ]
    }
  ]
}
