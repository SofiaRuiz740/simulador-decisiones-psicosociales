{
  "id": "entrevista-madre-espera",
  "titulo": "Madre de Lucía en sala de espera",
  "escenarioId": "consulta-inicial",
  "personajeId": "madre-lucia",
  "nodoInicialId": "apertura",
  "cuentaComoUtil": true,
  "nodos": [
    {
      "id": "apertura",
      "emisor": "personaje",
      "personajeId": "madre-lucia",
      "texto": "Perdón… soy la mamá de Lucía. Está en UCI y nadie me explica cómo sigue… estoy destrozada. Perdí a mi nieta Sofi hace unas horas y no doy abasto. Las cosas en esa casa siempre fueron complicadas, pero nunca pensé que llegaría a esto.",
      "siguienteNodoId": "decision-noticia"
    },
    {
      "id": "decision-noticia",
      "emisor": "jugador",
      "texto": "Habla como abuela en duelo y como madre preocupada. Piense cómo responder.",
      "opciones": [
        {
          "id": "validar-duelo",
          "texto": "«Lamento mucho la muerte de su nieta. Comprendo lo difícil que es esperar noticias de Lucía.»",
          "estrategiaClinica": "validacion_emocional",
          "siguienteNodoId": "lucia-alivia",
          "modificadoresMetricas": {
            "confianza": 10,
            "aperturaEmocional": 8
          },
          "efectos": [
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "criterio_pai",
                "valor": true
              }
            },
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "criterio_comunicacion_empatica",
                "valor": true
              }
            },
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "criterio_manejo_familiares_crisis",
                "valor": true
              }
            }
          ]
        },
        {
          "id": "indagar-hechos",
          "texto": "«Si puede, me ayudaría entender qué pasó antes de que Lucía ingresara.»",
          "estrategiaClinica": "exploracion",
          "siguienteNodoId": "lucia-defensiva"
        },
        {
          "id": "contener-silencio",
          "texto": "Permanezco a su lado en silencio, escuchando sin interrumpir ni juzgar.",
          "estrategiaClinica": "escucha_activa",
          "siguienteNodoId": "lucia-pausa",
          "efectos": [
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "criterio_escucha_activa",
                "valor": true
              }
            },
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "criterio_pai",
                "valor": true
              }
            }
          ]
        }
      ]
    },
    {
      "id": "lucia-alivia",
      "emisor": "personaje",
      "personajeId": "madre-lucia",
      "texto": "Sofi no merecía esto… En la casa de Lucía siempre había discusiones, sí, pero eran normales en parejas con hijos. Yo pensé que algún día se arreglarían… no así, Dios mío, no así.",
      "siguienteNodoId": "decision-episodio"
    },
    {
      "id": "lucia-defensiva",
      "emisor": "personaje",
      "personajeId": "madre-lucia",
      "texto": "No fue a propósito… Miguel, el yerno de Lucía, nunca haría algo así a propósito. Él se altera, sí, pero también tenía cosas buenas. No es mala persona.",
      "testimonio": {
        "id": "testimonio-madre-minimizacion",
        "tema": "clima_familiar",
        "valor": "minimizacion_yerno",
        "descripcion": "Madre de Lucía minimiza conducta del yerno Miguel",
        "personajeId": "madre-lucia"
      },
      "siguienteNodoId": "decision-episodio"
    },
    {
      "id": "lucia-pausa",
      "emisor": "personaje",
      "personajeId": "madre-lucia",
      "texto": "Perdón… no sé por dónde empezar. Tengo miedo de empeorar las cosas para Lucía si hablo de más de la cuenta.",
      "siguienteNodoId": "decision-episodio"
    },
    {
      "id": "decision-episodio",
      "emisor": "jugador",
      "texto": "Hay varias líneas para seguir. Piense qué explorar primero.",
      "opciones": [
        {
          "id": "explorar-antecedentes",
          "texto": "«Antes de seguir, ¿esto había pasado otras veces?»",
          "estrategiaClinica": "exploracion",
          "siguienteNodoId": "madre-antecedentes",
          "efectos": [
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "criterio_ciclo_violencia",
                "valor": true
              }
            },
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "criterio_factores_riesgo",
                "valor": true
              }
            }
          ]
        },
        {
          "id": "explorar-red-apoyo",
          "texto": "«¿Con quién cuenta Lucía cuando las cosas se ponen difíciles?»",
          "estrategiaClinica": "exploracion",
          "siguienteNodoId": "madre-red-apoyo",
          "efectos": [
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "criterio_factores_protectores",
                "valor": true
              }
            }
          ]
        },
        {
          "id": "explorar-relacion-agresor",
          "texto": "«¿Cómo era la relación entre Lucía y Miguel antes de esta noche?»",
          "estrategiaClinica": "evaluacion_riesgo",
          "siguienteNodoId": "madre-relacion-miguel",
          "efectos": [
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "criterio_factores_riesgo",
                "valor": true
              }
            }
          ]
        },
        {
          "id": "preguntar-presencia",
          "texto": "«¿Quién estaba en la casa cuando empezó la discusión?»",
          "estrategiaClinica": "exploracion",
          "siguienteNodoId": "madre-presencia"
        }
      ]
    },
    {
      "id": "madre-antecedentes",
      "emisor": "personaje",
      "personajeId": "madre-lucia",
      "texto": "Bueno… sí, había gritos casi cada semana. Una vez la empujó contra la nevera; la policía vino por los ruidos, pero Lucía no quiso denunciar. Yo pensé que iría pasando, que las discusiones eran normales en parejas tensas.",
      "testimonio": {
        "id": "testimonio-madre-ciclo-violencia",
        "tema": "clima_familiar",
        "valor": "violencia_sostenida",
        "descripcion": "Madre reconoce episodios previos y escalamiento de violencia",
        "personajeId": "madre-lucia"
      },
      "siguienteNodoId": "decision-proteccion"
    },
    {
      "id": "madre-red-apoyo",
      "emisor": "personaje",
      "personajeId": "madre-lucia",
      "texto": "Conmigo y con Diego, a veces con una vecina. No la dejamos sola del todo: yo voy casi todos los días y él se queda cuando puede. Pero Miguel controlaba con quién hablaba; decía que la familia era ‘envidiosa’.",
      "siguienteNodoId": "decision-proteccion"
    },
    {
      "id": "madre-relacion-miguel",
      "emisor": "personaje",
      "personajeId": "madre-lucia",
      "texto": "Empezó bien… luego celos, control del dinero, más gritos. Lucía dejó de salir con amigas; decía que ‘no era para tanto’. Yo la veía más callada cada mes. Esta noche se sintió distinto, sí.",
      "siguienteNodoId": "decision-proteccion"
    },
    {
      "id": "madre-presencia",
      "emisor": "personaje",
      "personajeId": "madre-lucia",
      "texto": "Estábamos Lucía, Sofi, Miguel y mi hijo Diego. Yo fui a llevarles comida… llegué cuando ya gritaban. Miguel tenía los puños cerrados, pero en una discusión eso pasa.",
      "siguienteNodoId": "decision-proteccion"
    },
    {
      "id": "decision-proteccion",
      "emisor": "jugador",
      "texto": "El relato toca temas sensibles. Piense cómo profundizar sin retraumatizar.",
      "opciones": [
        {
          "id": "explorar-roles-familia",
          "texto": "«¿Quién vivía en la casa de Lucía y quién vio lo que pasó?»",
          "estrategiaClinica": "exploracion",
          "siguienteNodoId": "madre-convivencia"
        },
        {
          "id": "explorar-miedo",
          "texto": "«¿A quién siente que está protegiendo cuando no habla de todo?»",
          "estrategiaClinica": "evaluacion_riesgo",
          "siguienteNodoId": "madre-miedo"
        },
        {
          "id": "explorar-duelo-familiar",
          "texto": "«¿Cómo recibió la noticia de Sofi y cómo se siente ahora?»",
          "estrategiaClinica": "validacion_emocional",
          "siguienteNodoId": "madre-duelo-hospital",
          "efectos": [
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "info_eval_psicosocial_familiar",
                "valor": true
              }
            }
          ]
        },
        {
          "id": "explorar-apoyo-colaboracion",
          "texto": "«¿Estaría dispuesta a acompañar a Lucía y colaborar con el equipo?»",
          "estrategiaClinica": "exploracion",
          "siguienteNodoId": "madre-colaboracion-institucional",
          "efectos": [
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "info_factores_protectores_familia",
                "valor": true
              }
            }
          ]
        },
        {
          "id": "explorar-contradiccion",
          "texto": "«Hay cosas que todavía no comprendo entre lo que cuenta la familia. ¿Lo revisamos juntas?»",
          "estrategiaClinica": "confrontacion",
          "siguienteNodoId": "madre-contradiccion",
          "modificadoresMetricas": {
            "confianza": -5,
            "aperturaEmocional": 5
          }
        }
      ]
    },
    {
      "id": "madre-convivencia",
      "emisor": "personaje",
      "personajeId": "madre-lucia",
      "texto": "Lucía vivía con Miguel y Sofi. Diego pasa mucho tiempo allá. Miguel duerme en la casa casi todas las noches… aunque a veces ‘se va a enfriar’ cuando se altera demasiado.",
      "siguienteNodoId": "decision-cierre-madre"
    },
    {
      "id": "madre-miedo",
      "emisor": "personaje",
      "personajeId": "madre-lucia",
      "texto": "Tengo miedo de que, si hablo mal de Miguel, le prohíban ver a Lucía… o que él vuelva y le haga daño otra vez. Perdí a mi nieta… no puedo perder también a mi hija.",
      "siguienteNodoId": "decision-cierre-madre"
    },
    {
      "id": "madre-duelo-hospital",
      "emisor": "personaje",
      "personajeId": "madre-lucia",
      "texto": "Me enteré en la ambulancia… no lo creí. Ahora siento un vacío y culpa a la vez. Duermo mal, no como… pero no me puedo ir: Lucía necesita que yo esté aquí cuando despierte.",
      "siguienteNodoId": "madre-afrontamiento-duelo"
    },
    {
      "id": "madre-afrontamiento-duelo",
      "emisor": "personaje",
      "personajeId": "madre-lucia",
      "texto": "A veces lloro y me paralizo; otras me obligo a ser fuerte por Diego. No sé si podré sostener el duelo y cuidar a Lucía al mismo tiempo… pero lo intentaré.",
      "siguienteNodoId": "decision-cierre-madre"
    },
    {
      "id": "madre-colaboracion-institucional",
      "emisor": "personaje",
      "personajeId": "madre-lucia",
      "texto": "Sí… quiero que Lucía se recupere. Si hablar ayuda a protegerla, lo haré, aunque me dé miedo. Prefiero que me expliquen qué sigue antes de firmar cualquier cosa, pero estoy dispuesta a acompañarla.",
      "siguienteNodoId": "decision-cierre-madre"
    },
    {
      "id": "madre-contradiccion",
      "emisor": "personaje",
      "personajeId": "madre-lucia",
      "texto": "Es que… cada uno recuerda distinto cuando hay miedo. Yo dije lo de la caída porque Lucía me miraba suplicando. Pero Diego vio otra cosa… eso lo sé, aunque me cueste admitirlo.",
      "siguienteNodoId": "decision-cierre-madre"
    },
    {
      "id": "decision-cierre-madre",
      "emisor": "jugador",
      "texto": "La entrevista puede cerrarse. Piense cómo sostener lo conversado.",
      "opciones": [
        {
          "id": "derivar-apoyo",
          "texto": "«Su testimonio puede ayudar a proteger a Lucía. Estoy aquí para acompañarla.»",
          "estrategiaClinica": "contencion_emocional",
          "siguienteNodoId": "cierre-madre-dialogo",
          "efectos": [
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "criterio_decision_etica",
                "valor": true
              }
            }
          ]
        },
        {
          "id": "pedir-testigo",
          "texto": "«¿Le parece bien que hable con Diego por separado para entender mejor lo ocurrido?»",
          "estrategiaClinica": "exploracion",
          "siguienteNodoId": "cierre-madre-dialogo"
        }
      ]
    },
    {
      "id": "cierre-madre-dialogo",
      "emisor": "personaje",
      "personajeId": "madre-lucia",
      "texto": "Mi hijo Diego sabe más de lo que dice… pero tiene miedo de señalar a Miguel. Creo que la enfermera del pasillo vio cómo discutíamos al ingresar. Por favor, cuíden a Lucía.",
      "siguienteNodoId": "format-ref-d2-madre"
    },
    {
      "id": "format-ref-d2-madre",
      "emisor": "jugador",
      "texto": "Mientras acompaña a Carmen en el duelo, considere qué necesita más atención ahora mismo.",
      "opciones": [
        {
          "id": "format-d2-a",
          "texto": "Obtención de detalles judiciales.",
          "estrategiaClinica": "exploracion",
          "siguienteNodoId": "feedback-format-d2-a",
          "efectos": [
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "format_ref_d2",
                "valor": "A"
              }
            }
          ]
        },
        {
          "id": "format-d2-b",
          "texto": "Contención emocional y duelo agudo.",
          "estrategiaClinica": "contencion_emocional",
          "siguienteNodoId": "feedback-format-d2-b",
          "efectos": [
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "format_ref_d2",
                "valor": "B"
              }
            }
          ]
        },
        {
          "id": "format-d2-c",
          "texto": "Investigación de antecedentes penales.",
          "estrategiaClinica": "exploracion",
          "siguienteNodoId": "feedback-format-d2-c",
          "efectos": [
            {
              "tipo": "establecer_flag",
              "parametros": {
                "clave": "format_ref_d2",
                "valor": "C"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "feedback-format-d2-a",
      "emisor": "narrador",
      "texto": "Pedir detalles judiciales ahora puede subirle la ansiedad a alguien en duelo agudo.",
      "siguienteNodoId": "cierre-madre"
    },
    {
      "id": "feedback-format-d2-b",
      "emisor": "narrador",
      "texto": "Contener el duelo primero facilita que la familia pueda aportar información con más claridad después.",
      "siguienteNodoId": "cierre-madre"
    },
    {
      "id": "feedback-format-d2-c",
      "emisor": "narrador",
      "texto": "Los antecedentes penales pueden revisarse cuando la persona esté un poco más estable emocionalmente.",
      "siguienteNodoId": "cierre-madre"
    },
    {
      "id": "cierre-madre",
      "emisor": "narrador",
      "texto": "Cierra la entrevista con la madre de Lucía. La familia sigue en sala de espera.",
      "efectosAlMostrar": [
        {
          "tipo": "completar_conversacion",
          "parametros": {
            "conversacionId": "entrevista-madre-espera"
          }
        }
      ]
    }
  ]
}
