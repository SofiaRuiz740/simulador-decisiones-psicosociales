      "emisor": "personaje",
      "personajeId": "trabajadora-social-comisaria",
      "texto": "Hay duelo, miedo a represalias y dudas sobre retorno seguro al domicilio. Lucía está en recuperación parcial, fuera de UCI. Puedo ampliar según lo recogido en el hospital.",
      "siguienteNodoId": "decision-prep-profundizacion"
    },
    {
      "id": "decision-prep-profundizacion",
      "emisor": "jugador",
      "texto": "Puede profundizar en factores de riesgo y protección. Considera qué indagar a continuación.",
      "opciones": [
        {
          "id": "prep-slot-ts-profundizacion-1",
          "texto": "«Necesito articular con ustedes la derivación interdisciplinaria y el plan de seguridad.»",
          "estrategiaClinica": "exploracion",
          "siguienteNodoId": "ts-articulacion",
          "efectos": [
