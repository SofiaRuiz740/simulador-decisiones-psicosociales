    },
    {
      "id": "decision-prep-exploracion-inicial",
      "emisor": "jugador",
      "texto": "La articulación interinstitucional está abierta; organiza mentalmente cómo encuadrar la exploración inicial.",
      "opciones": [
        {
          "id": "prep-slot-ts-exploracion-1",
          "texto": "«¿Qué red de apoyo institucional pueden activar para la familia en esta etapa?»",
          "estrategiaClinica": "exploracion",
          "siguienteNodoId": "ts-explor-red",
          "efectos": [
            {
              "tipo": "establecer_flag",
