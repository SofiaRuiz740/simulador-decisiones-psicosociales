          "estrategiaClinica": "validacion_emocional",
          "siguienteNodoId": "lucia-alivia",
          "modificadoresMetricas": { "confianza": 10, "aperturaEmocional": 8 }
        },
        {
          "id": "indagar-hechos",
          "texto": "Explorar qué recuerda del episodio que originó el ingreso.",
          "estrategiaClinica": "exploracion",
          "siguienteNodoId": "lucia-defensiva"
        },
        {
          "id": "contener-silencio",
          "texto": "Ofrecer presencia en silencio y esperar a que ella elija qué contar.",
          "estrategiaClinica": "contencion_emocional",
          "siguienteNodoId": "lucia-pausa"
        }
      ]
    },
    {
      "id": "lucia-alivia",
      "emisor": "personaje",
      "personajeId": "lucia",
      "texto": "Ella no merecía esto… En casa siempre había gritos, yo pensé que algún día pasaría algo peor.",
      "siguienteNodoId": "decision-proteccion"
    },
    {
      "id": "lucia-defensiva",
      "emisor": "personaje",
      "personajeId": "lucia",
      "texto": "No fue a propósito… Miguel nunca haría algo así a propósito.",
      "siguienteNodoId": "decision-proteccion"
    },
    {
      "id": "lucia-pausa",
      "emisor": "personaje",
      "personajeId": "lucia",
      "texto": "Perdón… no sé por dónde empezar. Tengo miedo de empeorar las cosas.",
      "siguienteNodoId": "decision-proteccion"
    },
    {
      "id": "decision-proteccion",
      "emisor": "jugador",
      "texto": "Cómo profundizar sin retraumatizar",
      "opciones": [
        {
          "id": "explorar-roles-familia",
          "texto": "Preguntar quién convivía en el hogar y quién presenció la agresión.",
