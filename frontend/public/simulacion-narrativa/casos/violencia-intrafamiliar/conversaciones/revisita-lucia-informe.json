{
  "id": "revisita-lucia-informe",
  "titulo": "Acercamiento a la paciente en UCI",
  "escenarioId": "consulta-inicial",
  "personajeId": "lucia",
  "nodoInicialId": "saludo-revisita",
  "noConsumeConversacionUtil": true,
  "requisitosAcceso": [
    {
      "tipo": "evidencia_descubierta",
      "parametros": {
