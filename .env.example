# =========================================================
# .env.example
# Plantilla pública de variables de entorno.
# Copiar este archivo a `.env` y completar valores reales.
# El archivo `.env` NUNCA debe subirse al repositorio.
# =========================================================

# ---------- Django ----------
SECRET_KEY=cambiar-esta-clave-en-produccion
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ---------- PostgreSQL ----------
POSTGRES_DB=simulador_db
POSTGRES_USER=simulador_user
POSTGRES_PASSWORD=simulador_pass
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Puerto expuesto al host (Windows) — 5435 para no chocar con simulador_narrativo (5436).
POSTGRES_HOST_PORT=5435

# Puertos del stack destino (ORIGEN usa 8001/8081)
BACKEND_HOST_PORT=8000
FRONTEND_HOST_PORT=8080

# ---------- CORS ----------
# URLs del frontend autorizadas a consumir la API (separadas por coma)
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost:8080,http://127.0.0.1:8080

# ---------- JWT ----------
# Tiempo de vida del access token en minutos
JWT_ACCESS_LIFETIME_MIN=60
# Tiempo de vida del refresh token en días
JWT_REFRESH_LIFETIME_DAYS=7

# ---------- IA generativa ----------
# Provider: "openai" / "anthropic" / "groq"
AI_PROVIDER=openai
# Modelo a usar — depende del provider:
# - openai:    gpt-4o-mini, gpt-4o, gpt-4-turbo
# - anthropic: claude-3-5-sonnet-latest, claude-3-5-haiku-latest
# - groq:      llama-3.3-70b-versatile (free tier), llama-3.1-8b-instant
AI_MODEL=gpt-4o-mini
# Temperatura 0.0–1.0 (más alto = más creativo, menos predecible)
AI_TEMPERATURE=0.7
# Solo se necesita la del provider elegido.
# Si no hay key, el backend usa un stub plausible (generada_con_llm=False).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ---------- Correo (cada docente usa SU cuenta Gmail) ----------
# Servidor SMTP global. Cada docente guarda su clave de aplicación Gmail en
# Perfil → "Correo para invitaciones" (campo `correo_smtp_password`). Esa clave
# se usa para enviar:
#   - invitaciones a prácticas con código (RF28)
#   - notificaciones de revocación (RN26)
#   - notificaciones de nota final (RF42) — con fallback a DEFAULT_FROM_EMAIL
#     si el docente no tiene clave configurada
#
# Cómo obtener una clave de aplicación de Gmail (16 caracteres):
#   1. Activar verificación en 2 pasos en https://myaccount.google.com/security
#   2. Generar clave en https://myaccount.google.com/apppasswords
#   3. Pegarla en el dialog del perfil del docente (NUNCA en .env real).
#
# En desarrollo, si prefieres NO enviar correos reales y solo ver el contenido
# en la consola del backend, cambia EMAIL_BACKEND a console.EmailBackend.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
# Remitente por defecto cuando un docente no tiene SMTP configurado (ej:
# notificación de nota cuando el docente no ha entrado a configurar su clave).
DEFAULT_FROM_EMAIL=no-reply@simulador.local
# URL pública del frontend, usada en el cuerpo de los correos.
FRONTEND_URL=http://localhost:4200

# Cierre automático de prácticas vencidas (RN27):
# Programar este comando cada N minutos (cron del sistema o tarea programada):
#   docker compose exec backend python manage.py cerrar_practicas_vencidas
# Soporta --dry-run para verificar sin tocar BD.

# ---------- Administrador de plataforma (seed_admin) ----------
# Usuario con rol ADMIN para panel Angular /admin y Django Admin.
# Ejecutar: docker compose exec backend python manage.py seed_admin
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@simulador.local
ADMIN_PASSWORD=Admin123!
