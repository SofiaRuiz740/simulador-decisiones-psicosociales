    {
      "id": "ts-derivacion-clinica",
      "emisor": "personaje",
      "personajeId": "trabajadora-social-comisaria",
      "texto": "En esta etapa de recuperación, derivaremos a psicología para trauma y valoración psiquiátrica si hay síntomas severos. Usted puede anticipar en su informe la necesidad de psicoterapia sostenida.",
